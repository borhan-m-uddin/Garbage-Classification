# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment (entire folder)
.venv/
venv/
env/

# Dataset folder (large - do not upload)
Garbage_Classification_Dataset/

# Output folder - ignore EVERYTHING inside by default
Garbage_Classification_Outputs/

