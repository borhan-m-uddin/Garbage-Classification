# !Garbage_Classification_Outputs/confusion_matrix.png
# !Garbage_Classification_Outputs/training_metrics.png
# !Garbage_Classification_Outputs/augmentation_demo.png   # (if it exists)

# IDE files (optional but good to ignore)
.vscode/
.idea/
*.iml

# System files
.DS_Store
Thumbs.db